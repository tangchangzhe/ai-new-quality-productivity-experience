# Server
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example

# MySQL. Use either DATABASE_URL or the split MYSQL_* values.
DATABASE_URL=mysql://db_user:db_password@127.0.0.1:3306/ai_productivity
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=db_user
MYSQL_PASSWORD=db_password
MYSQL_DATABASE=ai_productivity

# Vercel AI Gateway
# AI SDK v6 reads AI_GATEWAY_API_KEY. VERCEL_GATEWAY_API_KEY is accepted by this app as an alias.
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key
VERCEL_GATEWAY_API_KEY=
AI_MOCK=false

# Model IDs passed to Vercel AI Gateway.
# Replace these with the exact model identifiers enabled in your Vercel account.
MODEL_DEEPSEEK=deepseek/deepseek-v4-pro
MODEL_GEMINI=google/gemini-3.5-flash
MODEL_GPT=openai/gpt-5.5
MODEL_CLAUDE=anthropic/claude-opus-4.6

# Scoring AI. Per requirement, this should stay DeepSeek V4 Pro unless you intentionally change it.
MODEL_EVALUATOR=deepseek/deepseek-v4-pro
MODEL_RESONANCE=deepseek/deepseek-v4-pro

# Generation controls
AI_TEMPERATURE=0.7
AI_MAX_OUTPUT_TOKENS=500
AI_TOTAL_TIMEOUT_MS=90000
AI_CHUNK_TIMEOUT_MS=20000
